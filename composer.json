{
    "name": "marshmallow/nova-fontawesome",
    "description": "A Font Awesome 6 Field for Laravel Nova 5",
    "keywords": [
        "laravel",
        "nova",
        "nova 5",
        "fontawesome 6",
        "fontawesome"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "laravel/nova": "^5.0"
    },
    "require-dev": {
        "laravel/nova-devtool": "^1.8",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0",
        "outl1ne/nova-translations-loader": "^5.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "outl1ne/nova-translations-loader": "Required for translation support (^5.0)"
    },
    "autoload": {
        "psr-4": {
            "Marshmallow\\NovaFontAwesome\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marshmallow\\NovaFontAwesome\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Marshmallow\\NovaFontAwesome\\FieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "lint": "vendor/bin/pint",
        "lint-check": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse"
    }
}
